# ══════════════════════════════════════════════════════════════
#  YouTube Brand Sentiment Dashboard — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── YouTube Data API v3 ────────────────────────────────────────
# Get a key at https://console.developers.google.com/
# Enable "YouTube Data API v3" for your project.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Flask ──────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_strong_random_string
FLASK_ENV=development        # development | production

# ── PostgreSQL Database ────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://sentiment_user:your_password@localhost:5432/sentiment_db

# ── Caching ────────────────────────────────────────────────────
# Seconds to cache an analysis result (default 10 min)
CACHE_TIMEOUT=600

# ── Analysis Limits ────────────────────────────────────────────
# Max YouTube videos to scan per keyword request
MAX_VIDEOS=5
# Max comments to fetch per video (YouTube API cap: 100)
MAX_COMMENTS_PER_VIDEO=20

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated allowed origins (use * to allow all in dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Sentiment Model ────────────────────────────────────────────
# Which analyzer to use: vader (default) | roberta
# vader  — fast, 3-class (positive / negative / neutral), no GPU needed
# roberta — local Twitter-RoBERTa, 2-class (positive / negative), requires torch
SENTIMENT_MODEL=vader

# Absolute or relative path to the directory containing model.safetensors,
# tokenizer.json, config.json, and label_map.json.
# Relative paths are resolved from the backend directory.
# Default (when blank): ../../models  (i.e. <repo-root>/models)
ROBERTA_MODEL_PATH=
